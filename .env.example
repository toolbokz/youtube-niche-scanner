# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Growth Strategist — Environment Variables                                 ║
# ║  Copy this file to .env and fill in your values.                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Application ────────────────────────────────────────────────────────────────

# Environment: development | staging | production
GS_ENVIRONMENT=development

# Enable debug mode (true | false)
GS_DEBUG=true

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
GS_LOG_LEVEL=INFO

# Path to YAML config file (overrides default config.yaml)
GS_CONFIG_PATH=config.yaml

# ── Database ───────────────────────────────────────────────────────────────────

# SQLite (default — no setup required)
GS_DATABASE_URL=sqlite:///data/db/growth_strategist.db

# PostgreSQL (optional — uncomment to use instead of SQLite)
# GS_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/growth_strategist

# Echo SQL statements to log (true | false)
GS_DATABASE_ECHO=false

# Connection pool size (ignored for SQLite)
GS_DATABASE_POOL_SIZE=5

# ── API Server ─────────────────────────────────────────────────────────────────

# Host and port for the FastAPI server
GS_API_HOST=0.0.0.0
GS_API_PORT=8000
GS_API_WORKERS=4

# CORS allowed origins (comma-separated). Use * for dev, restrict in production.
GS_API_CORS_ORIGINS=*

# ── Cache ──────────────────────────────────────────────────────────────────────

# Enable disk + memory caching (true | false)
GS_CACHE_ENABLED=true

# Cache storage directory
GS_CACHE_DIRECTORY=data/cache

# Default time-to-live for cached items (hours)
GS_CACHE_TTL_HOURS=24

# Maximum cache size on disk (MB)
GS_CACHE_MAX_SIZE_MB=500

# ── YouTube Data API v3 (Optional) ────────────────────────────────────────────
# Provides enriched video/channel data. The system works without it using
# free scraping-based connectors, but enabling this improves accuracy.

# Set to true to enable the YouTube Data API connector
GS_YOUTUBE_DATA_API_ENABLED=false

# Your YouTube Data API v3 key (https://console.cloud.google.com/apis)
GS_YOUTUBE_DATA_API_KEY=

# ── Connector Rate Limits ──────────────────────────────────────────────────────
# Requests per second for each data source. Lower values are safer to avoid
# rate-limiting; raise only if you need faster throughput.

# YouTube Autocomplete (free, no key needed)
GS_YOUTUBE_AUTOCOMPLETE_RATE_LIMIT=2.0
GS_YOUTUBE_AUTOCOMPLETE_TIMEOUT=10
GS_YOUTUBE_AUTOCOMPLETE_CACHE_TTL_HOURS=12

# YouTube Search Scraping (free, no key needed)
GS_YOUTUBE_SEARCH_RATE_LIMIT=1.0
GS_YOUTUBE_SEARCH_TIMEOUT=15
GS_YOUTUBE_SEARCH_CACHE_TTL_HOURS=6

# Google Trends via pytrends (free, no key needed)
GS_GOOGLE_TRENDS_RATE_LIMIT=1.0
GS_GOOGLE_TRENDS_TIMEOUT=20
GS_GOOGLE_TRENDS_CACHE_TTL_HOURS=12

# Reddit JSON API (free, no key needed)
GS_REDDIT_RATE_LIMIT=1.0
GS_REDDIT_TIMEOUT=15
GS_REDDIT_CACHE_TTL_HOURS=6

# YouTube Data API v3 (requires key above)
GS_YOUTUBE_DATA_API_RATE_LIMIT=5.0
GS_YOUTUBE_DATA_API_TIMEOUT=10
GS_YOUTUBE_DATA_API_CACHE_TTL_HOURS=24

# Global max retries for all connectors
GS_CONNECTOR_MAX_RETRIES=3

# ── Analysis ───────────────────────────────────────────────────────────────────

# Maximum keywords to process in a single batch
GS_MAX_KEYWORDS_PER_BATCH=500

# Number of top niches to return in results
GS_TOP_NICHES_COUNT=20

# Video ideas to generate per niche
GS_VIDEOS_PER_NICHE=10

# Number of search results to sample for competition analysis
GS_COMPETITION_SAMPLE_SIZE=20

# ── Ranking Weights ────────────────────────────────────────────────────────────
# Must sum to 1.0 — controls how niches are scored and ranked.

GS_WEIGHT_DEMAND=0.25
GS_WEIGHT_COMPETITION=0.20
GS_WEIGHT_TREND_MOMENTUM=0.15
GS_WEIGHT_VIRALITY=0.15
GS_WEIGHT_CTR_POTENTIAL=0.10
GS_WEIGHT_VIRAL_OPPORTUNITY=0.10
GS_WEIGHT_TOPIC_VELOCITY=0.05

# ── Reports ────────────────────────────────────────────────────────────────────

# Directory where JSON and Markdown reports are saved
GS_REPORTS_OUTPUT_DIRECTORY=data/reports

# Output formats (comma-separated): json, markdown
GS_REPORTS_FORMAT=json,markdown

# ── Vertex AI (Gemini) ─────────────────────────────────────────────────────────

# Enable Vertex AI / Gemini integration (true | false)
GS_VERTEX_AI_ENABLED=false

# Google Cloud project ID for Vertex AI
GS_VERTEX_AI_PROJECT=

# Vertex AI region
GS_VERTEX_AI_REGION=us-central1

# OAuth 2.0 Client ID for Google Vertex AI
GS_VERTEX_CLIENT_ID=

# Cache TTL for AI responses (hours)
GS_VERTEX_AI_CACHE_TTL_HOURS=24
